#!/usr/bin/env sh

# for this to work you must configure sudo such that
# it will be able to run the command without password

# sudo yabai --load-sa

# yabai -m signal --add event=dock_did_restart action="sudo yabai --load-sa"
yabai -m signal --add event=window_focused action="sketchybar --trigger window_focus; sketchybar --trigger wm_focus_change"
yabai -m signal --add event=space_changed action="sketchybar --trigger wm_workspace_change FOCUSED_WORKSPACE=\$YABAI_SPACE_ID"
yabai -m signal --add event=display_changed action="sketchybar --trigger wm_focus_change"

# Options commented out below require the yabai scripting addition (SIP off):
#   window_topmost, window_opacity, active_window_opacity, normal_window_opacity,
#   window_animation_duration, window_animation_easing.
# `external_bar` is kept but the height lookup falls back gracefully if
# sketchybar isn't yet running at launch.
yabai -m config external_bar              all:$(sketchybar --query bar 2>/dev/null | jq -r '.height // 0'):0 \
                layout                    bsp            \
                mouse_follows_focus       on             \
                focus_follows_mouse       off            \
                window_zoom_persist       off            \
                window_origin_display     default        \
                window_placement          second_child   \
                window_shadow             on             \
                insert_feedback_color     0xff9dd274     \
                split_ratio               0.6            \
                auto_balance              off            \
                mouse_modifier            ctrl           \
                mouse_action1             move           \
                mouse_action2             resize         \
                mouse_drop_action         swap           \
                top_padding               10             \
                bottom_padding            10             \
                left_padding              10             \
                right_padding             10             \
                window_gap                10

## If I close or minimize the active window, focus on another visible one
## in the current space (fall back to the window under the mouse). Same
## handlers also kick sketchybar to refresh so stale icons clear.
focus_next='id=$(yabai -m query --windows --space | jq -r "[.[] | select(.\"has-focus\" == false and .\"is-minimized\" == false and .\"is-hidden\" == false)][0].id // empty") && [ -n "$id" ] && yabai -m window --focus "$id" || yabai -m window --focus mouse; sketchybar --trigger wm_focus_change'
yabai -m signal --add event=window_destroyed action="$focus_next"
yabai -m signal --add event=application_terminated action="$focus_next"
yabai -m signal --add event=window_minimized action="$focus_next"

## Sketchybar should also refresh when windows appear / come back.
yabai -m signal --add event=window_created action="sketchybar --trigger wm_focus_change"
yabai -m signal --add event=window_deminimized action="sketchybar --trigger wm_focus_change"

# yabai -m signal --add app='^Amazon Chime$' event=window_created action='yabai -m space --layout bsp'
# yabai -m signal --add app='^Amazon Chime$' event=window_destroyed action='yabai -m space --layout bsp'
# yabai -m signal --add app='^Amazon Chime$' event=window_minimized action='yabai -m space --layout bsp'
# yabai -m signal --add app='^Amazon Chime$' event=window_deminimized action='yabai -m space --layout bsp'

yabai -m rule --add app=".*" sub-layer=normal

# apps to not manage (ignore)
yabai -m rule --add app="^System Settings$" manage=off
yabai -m rule --add app="^Archive Utility$" manage=off
yabai -m rule --add app="^Stickies$" manage=off
yabai -m rule --add app="^Music$" manage=off
yabai -m rule --add app="^eqMac$" manage=off
yabai -m rule --add app="^borders$" manage=off
yabai -m rule --add app="^Cisco AnyConnect Secure Mobility Client$" manage=off
yabai -m rule --add app="^Cisco Secure Client$" manage=off
# yabai -m rule --add app="^Amazon Chime$" manage=off
yabai -m rule --add title="^Picture in Picture$" manage=off
yabai -m rule --add title="^Picture-in-Picture$" manage=off
yabai -m rule --add app="^Amazon Chime$" title="^Amazon Chime: Meeting Controls$" manage=off
yabai -m rule --add app="^Amazon Chime$" title="^Amazon Chime: Screen Share Border$" manage=off
yabai -m rule --add app="^Amazon Chime$" title="^Window$" manage=off
yabai -m rule --add app="^Amazon Chime$" title=".*Border$" manage=off
yabai -m rule --add app="^BetterDisplay$" manage=off
# yabai -m rule --add title="^$" manage=off

# borders active_color=0xe1f1e100 inactive_color=0xff494d64 width=15.0 &

echo "yabai configuration loaded.."
