alt - m : open -a "Gmail"
alt - c : open -a "Google Calendar"
alt - o : open -a "Obsidian"
alt - x : open -a "Cursor"
alt - p : open -a "Zen"
alt - b : open -a "Google Chrome"
alt - y : open -a "YouTube"

