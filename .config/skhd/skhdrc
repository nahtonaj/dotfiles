# focus window
alt - h : yabai -m window --focus west || yabai -m window --focus stack.prev || yabai -m display --focus west
alt - j : yabai -m window --focus south || yabai -m display --focus south
alt - k : yabai -m window --focus north || yabai -m display --focus north
alt - l : yabai -m window --focus east || yabai -m window --focus stack.next || yabai -m display --focus east

# swap managed window (fallback to focusing the adjacent display; the
# `window --display` cross-display move needs the SA so we drop it).
shift + alt - h : yabai -m window --swap west || yabai -m display --focus west
shift + alt - j : yabai -m window --swap south || yabai -m display --focus south
shift + alt - k : yabai -m window --swap north || yabai -m display --focus north
shift + alt - l : yabai -m window --swap east || yabai -m display --focus east

# move managed window
shift + alt + ctrl - h : yabai -m window --warp west
shift + alt + ctrl - j : yabai -m window --warp south
shift + alt + ctrl - k : yabai -m window --warp north
shift + alt + ctrl - l : yabai -m window --warp east

alt + cmd - h : yabai -m window west --resize right:-100:0 2> /dev/null || yabai -m window --resize right:-100:0
alt + cmd - j : yabai -m window north --resize bottom:0:100 2> /dev/null || yabai -m window --resize bottom:0:100
alt + cmd - k : yabai -m window south --resize top:0:-100 2> /dev/null || yabai -m window --resize top:0:-100
alt + cmd - l : yabai -m window east --resize left:100:0 2> /dev/null || yabai -m window --resize left:100:0

# balance size of windows
alt + cmd - 0 : yabai -m space --balance

# rotate tree
alt - r : yabai -m space --rotate 90

#focus recent
alt - u : yabai -m window --focus recent

# toggle window fullscreen zoom
alt - f : yabai -m window --toggle zoom-fullscreen

# Removed: sticky/pip toggles need the SA.

# toggle padding and gap
alt - g : yabai -m space --toggle padding; yabai -m space --toggle gap

# float / unfloat window and center on screen
alt - t : yabai -m window --toggle float;\
          yabai -m window --grid 20:20:1:1:18:18

# float / unfloat window and bottom-left on screen (sticky dropped - needs SA)
alt - p : yabai -m window --toggle float;\
          yabai -m window --grid 20:20:12:12:18:18

alt - m : yabai -m window --minimize

# toggle window split type
alt - e : yabai -m window --toggle split

# Focus space N (via Hammerspoon; SIP-free SLS API).
alt - 1 : open "hammerspoon://space_focus?n=1"
alt - 2 : open "hammerspoon://space_focus?n=2"
alt - 3 : open "hammerspoon://space_focus?n=3"
alt - 4 : open "hammerspoon://space_focus?n=4"
alt - 5 : open "hammerspoon://space_focus?n=5"
alt - 6 : open "hammerspoon://space_focus?n=6"
alt - 7 : open "hammerspoon://space_focus?n=7"
alt - 8 : open "hammerspoon://space_focus?n=8"
alt - 9 : open "hammerspoon://space_focus?n=9"

# Move focused window to space N and follow (via Hammerspoon).
alt + shift - 1 : open "hammerspoon://window_to_space_and_follow?n=1"
alt + shift - 2 : open "hammerspoon://window_to_space_and_follow?n=2"
alt + shift - 3 : open "hammerspoon://window_to_space_and_follow?n=3"
alt + shift - 4 : open "hammerspoon://window_to_space_and_follow?n=4"
alt + shift - 5 : open "hammerspoon://window_to_space_and_follow?n=5"
alt + shift - 6 : open "hammerspoon://window_to_space_and_follow?n=6"
alt + shift - 7 : open "hammerspoon://window_to_space_and_follow?n=7"
alt + shift - 8 : open "hammerspoon://window_to_space_and_follow?n=8"
alt + shift - 9 : open "hammerspoon://window_to_space_and_follow?n=9"



