      "Bash(whereis:*)",
      "Bash(whoami:*)",
      "Bash(git checkout:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh api:*)",
      "Bash(gh repo view:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue view:*)",
      "Bash(kubectl describe:*)",
      "Bash(kubectl get:*)",
      "Bash(kubectl logs:*)",
      "Bash(kubectl version)",
      "Bash(bazel query:*)",
      "Bash(bazel build:*)",
      "Bash(bazel test:*)",
      "Bash(python3 /home/jon.gao/.claude/plugins/cache/experimental-plugin-marketplace/bazel-universe/1.0.0/skills/bazel-universe/scripts/bazel.py:*)",
      "Bash(python3 ~/.claude/plugins/cache/experimental-plugin-marketplace/bazel-universe/1.0.0/skills/bazel-universe/scripts/bazel.py:*)",
      "Read(///home/jon.gao/.claude/plugins/cache/experimental-plugin-marketplace/bazel-universe/1.0.0/**)",
      "Read(~/.claude/plugins/cache/experimental-plugin-marketplace/bazel-universe/1.0.0/**)",
      "Skill(bazel-universe:bazel-universe)",
      "mcp__proxy__github__get_pull_request",
      "mcp__proxy__github__get_pull_request_diff",
      "mcp__proxy__github__get_pull_requests_by_user",
