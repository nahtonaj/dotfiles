  "model": "opus[1m]",
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node $HOME/.claude/helpers/hook-handler.cjs pre-bash",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/jon.gao/universe/experimental/richard-liu_data/db-agents/plugin/hooks/status-reporter.sh waiting_input",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/jon.gao/universe/experimental/richard-liu_data/db-agents/plugin/hooks/status-reporter.sh pre_tool",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "bash /home/jon.gao/universe/experimental/richard-liu_data/db-agents/plugin/hooks/auto-approve.sh",
            "timeout": 2000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node $HOME/.claude/helpers/hook-handler.cjs post-edit",
            "timeout": 10000
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/jon.gao/universe/experimental/richard-liu_data/db-agents/plugin/hooks/status-reporter.sh post_tool",
            "timeout": 5000
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node $HOME/.claude/helpers/hook-handler.cjs route",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/helpers/tmux-pane-title.sh",
            "timeout": 3000
          },
          {
            "type": "command",
            "command": "bash /home/jon.gao/universe/experimental/richard-liu_data/db-agents/plugin/hooks/status-reporter.sh running",
            "timeout": 5000
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node $HOME/.claude/helpers/hook-handler.cjs session-restore",
            "timeout": 15000
          },
          {
            "type": "command",
            "command": "node $HOME/.claude/helpers/auto-memory-hook.mjs import",
            "timeout": 8000
          },
          {
            "type": "command",
            "command": "bash /home/jon.gao/universe/experimental/richard-liu_data/db-agents/plugin/hooks/status-reporter.sh idle",
            "timeout": 5000
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node $HOME/.claude/helpers/hook-handler.cjs session-end",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "bash /home/jon.gao/dotfiles/.claude/helpers/team-cleanup.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/helpers/dashboard-state.sh session-end",
            "timeout": 3000
          },
          {
            "type": "command",
            "command": "bash /home/jon.gao/universe/experimental/richard-liu_data/db-agents/plugin/hooks/status-reporter.sh disconnected",
            "timeout": 5000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node $HOME/.claude/helpers/auto-memory-hook.mjs sync",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/helpers/dashboard-state.sh session-complete",
            "timeout": 3000
          },
          {
            "type": "command",
            "command": "printf '\\a' > /dev/tty 2>/dev/null || true",
            "timeout": 3000
          },
          {
            "type": "command",
            "command": "bash /home/jon.gao/universe/experimental/richard-liu_data/db-agents/plugin/hooks/status-reporter.sh idle",
            "timeout": 5000
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "manual",
        "hooks": [
          {
            "type": "command",
            "command": "node $HOME/.claude/helpers/hook-handler.cjs compact-manual"
          },
          {
            "type": "command",
            "command": "node $HOME/.claude/helpers/hook-handler.cjs session-end",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "auto",
        "hooks": [
          {
            "type": "command",
            "command": "node $HOME/.claude/helpers/hook-handler.cjs compact-auto"
          },
          {
            "type": "command",
            "command": "node $HOME/.claude/helpers/hook-handler.cjs session-end",
            "timeout": 6000
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/jon.gao/universe/experimental/richard-liu_data/db-agents/plugin/hooks/status-reporter.sh compacting",
            "timeout": 5000
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node $HOME/.claude/helpers/hook-handler.cjs status",
            "timeout": 3000
          },
          {
            "type": "command",
            "command": "bash /home/jon.gao/universe/experimental/richard-liu_data/db-agents/plugin/hooks/status-reporter.sh running",
            "timeout": 5000
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/jon.gao/universe/experimental/richard-liu_data/db-agents/plugin/hooks/status-reporter.sh running",
            "timeout": 5000
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/jon.gao/universe/experimental/richard-liu_data/db-agents/plugin/hooks/status-reporter.sh permission_request",
            "timeout": 5000
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "/home/jon.gao/.config/llm-cli/hooks/claude_notification_hook.sh"
          }
        ]
      },
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "/home/jon.gao/.config/llm-cli/hooks/claude_notification_hook.sh"
          },
          {
            "type": "command",
            "command": "bash /home/jon.gao/universe/experimental/richard-liu_data/db-agents/plugin/hooks/status-reporter.sh idle",
            "timeout": 5000
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node /home/jon.gao/.claude/helpers/statusline.cjs 2>> /tmp/statusline-stderr.log"
  },
  "enabledPlugins": {
    "bazel-universe@experimental-plugin-marketplace": true,
    "spec-driven-workflow@experimental-plugin-marketplace": false,
    "pr-review-toolkit@claude-plugins-official": true,
