# ~/.zshrc — symlinked from dotfiles via nix/modules/zsh.nix.
# Mutable: edit directly, changes take effect on next shell without rebuild.
# Target: interactive shell ready in ~100ms.

# ─── Env & PATH ────────────────────────────────────────────────────────
if [ -e "$HOME/.nix-profile/etc/profile.d/nix.sh" ]; then
    . "$HOME/.nix-profile/etc/profile.d/nix.sh"
fi

export EDITOR=nvim
export NVM_DIR="$HOME/.nvm"
export SDKMAN_DIR="$HOME/.sdkman"

typeset -U path cdpath fpath manpath
path=(
    "$HOME/bin"
    /usr/local/bin
    /home/linuxbrew/.linuxbrew/bin
    "$HOME/.local/bin"
    "$HOME/.local/share/coursier/bin"
    $path
)
# Linux: JAVA_HOME for Metals (no-op if absent)
[ -d /usr/lib/jvm/java-17-openjdk-amd64 ] && export JAVA_HOME=/usr/lib/jvm/java-17-openjdk-amd64 && path+=("$JAVA_HOME/bin")

# fpath: pull in completions from every nix profile
for profile in ${(z)NIX_PROFILES}; do
    fpath+=($profile/share/zsh/site-functions $profile/share/zsh/$ZSH_VERSION/functions $profile/share/zsh/vendor-completions)
done

# ─── History ───────────────────────────────────────────────────────────
HISTFILE=$HOME/.zsh_history
HISTSIZE=10000
SAVEHIST=10000
mkdir -p "${HISTFILE:h}"
setopt HIST_FCNTL_LOCK HIST_IGNORE_DUPS HIST_IGNORE_SPACE SHARE_HISTORY
setopt NO_APPEND_HISTORY NO_EXTENDED_HISTORY NO_HIST_EXPIRE_DUPS_FIRST
setopt NO_HIST_FIND_NO_DUPS NO_HIST_IGNORE_ALL_DUPS NO_HIST_SAVE_NO_DUPS

# ─── Aliases ───────────────────────────────────────────────────────────
alias ll='ls -al'
alias jp='jupyter-lab --no-browser'
alias lg='lazygit'
alias vim='nvim'
# Cherry-picked git aliases
alias ga='git add'
alias gaa='git add --all'
alias gb='git branch'
alias gc='git commit'
alias gcam='git commit --all --message'
alias gcmsg='git commit --message'
alias gco='git checkout'
alias gd='git diff'
alias gds='git diff --staged'
alias gf='git fetch'
alias gl='git pull'
alias glog='git log --oneline --decorate --graph'
alias gp='git push'
alias gpf='git push --force-with-lease'
alias grb='git rebase'
alias grbi='git rebase --interactive'
alias gst='git status'
alias gsw='git switch'
alias gswc='git switch --create'

# Optional work aliases (databricks.nix only drops this on linux).
[ -f "$HOME/dotfiles/configs/aliasrc" ] && source "$HOME/dotfiles/configs/aliasrc"

# ─── Plugin bundle (compute path; actual source is after compinit) ─────
# antidote lives at ~/.config/antidote via nix/modules/zsh.nix.
_antidote_src="$HOME/.config/antidote/antidote.zsh"
_plugins_txt="$HOME/dotfiles/configs/zsh/zsh_plugins.txt"
_plugins_zsh="$HOME/.cache/zsh/zsh_plugins.zsh"
if [[ -r $_antidote_src && -r $_plugins_txt ]]; then
    if [[ ! $_plugins_zsh -nt $_plugins_txt ]]; then
        mkdir -p "${_plugins_zsh:h}"
        (source "$_antidote_src" && antidote bundle <"$_plugins_txt" >|"$_plugins_zsh")
    fi
fi

# ─── Completions BEFORE plugins ────────────────────────────────────────
# fzf-tab (and fast-syntax-highlighting's awareness of compdef widgets)
# require compinit to have run before they load. compinit cache gated on
# plugin bundle changes — not time — so dev hygiene doesn't cost startup.
autoload -Uz compinit
if [[ ! -f ~/.zcompdump ]] || [[ $_plugins_zsh -nt ~/.zcompdump ]]; then
    compinit
    [[ -f ~/.zcompdump ]] && { zcompile -M ~/.zcompdump ~/.zcompdump } &!
else
    compinit -C
fi

# Now source the plugin bundle (fzf-tab → fast-syntax-highlighting order is
# handled by zsh_plugins.txt).
[[ -r $_plugins_zsh ]] && source "$_plugins_zsh"
unset _antidote_src _plugins_txt _plugins_zsh

# ─── Cached zoxide + fzf init (regenerated when binary is newer) ────────
_zoxide_bin=$(command -v zoxide 2>/dev/null)
_zoxide_init="$HOME/.cache/zsh/zoxide-init.zsh"
if [[ -n $_zoxide_bin ]]; then
    if [[ ! -f $_zoxide_init || $_zoxide_bin -nt $_zoxide_init ]]; then
        mkdir -p "${_zoxide_init:h}"
        zoxide init zsh >|"$_zoxide_init"
    fi
    source "$_zoxide_init"
fi
unset _zoxide_bin _zoxide_init

_fzf_bin=$(command -v fzf 2>/dev/null)
_fzf_init="$HOME/.cache/zsh/fzf-init.zsh"
if [[ -n $_fzf_bin && $options[zle] = on ]]; then
    if [[ ! -f $_fzf_init || $_fzf_bin -nt $_fzf_init ]]; then
        mkdir -p "${_fzf_init:h}"
        fzf --zsh >|"$_fzf_init"
    fi
    source "$_fzf_init"
fi
unset _fzf_bin _fzf_init

# ─── Lazy NVM (source only on first use) ───────────────────────────────
if [ -s "$NVM_DIR/nvm.sh" ]; then
    _nvm_lazy_load() {
        unset -f nvm node npm npx yarn pnpm _nvm_lazy_load 2>/dev/null
        source "$NVM_DIR/nvm.sh"
        [ -s "$NVM_DIR/bash_completion" ] && source "$NVM_DIR/bash_completion"
    }
    for _cmd in nvm node npm npx yarn pnpm; do
        eval "$_cmd() { _nvm_lazy_load; $_cmd \"\$@\"; }"
    done
    unset _cmd
fi

# ─── Lazy SDKMAN ───────────────────────────────────────────────────────
if [[ -s "$SDKMAN_DIR/bin/sdkman-init.sh" ]]; then
    sdk() {
        unset -f sdk
        source "$SDKMAN_DIR/bin/sdkman-init.sh"
        sdk "$@"
    }
fi

# ─── Autosuggestions / syntax-highlighting config ──────────────────────
ZSH_AUTOSUGGEST_STRATEGY=(history)
ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE="fg=28"

# ─── Prompt ────────────────────────────────────────────────────────────
autoload -U colors && colors
setopt PROMPT_SUBST
[ -r "$HOME/dotfiles/configs/zsh/databricks.zsh-theme" ] && \
    source "$HOME/dotfiles/configs/zsh/databricks.zsh-theme"
COMPLETION_WAITING_DOTS=true

# ─── Vi-mode arrow key fix (history nav in all keymaps) ────────────────
() {
    while (( ARGC )); do
        bindkey -M $1 '^[OA' up-line-or-history
        bindkey -M $1 '^[[A' up-line-or-history
        bindkey -M $1 '^[OB' down-line-or-history
        bindkey -M $1 '^[[B' down-line-or-history
        shift
    done
} emacs viins vicmd

# ─── fzf-tab ───────────────────────────────────────────────────────────
# Hand rendering to fzf-tab. switch-group lets ,/./ jump between groups.
zstyle ':completion:*' menu no
zstyle ':completion:*:descriptions' format '[%d]'
zstyle ':fzf-tab:*' switch-group ',' '.'
zstyle ':fzf-tab:complete:*' fzf-preview '
    if [[ -d $realpath ]]; then
        ls -laG "$realpath" 2>/dev/null
    elif [[ -f $realpath ]]; then
        head -n 50 "$realpath" 2>/dev/null
    fi
'

# ─── Custom functions ──────────────────────────────────────────────────
set-title() { echo -e "\e]0;$*\007"; }

ssh() {
    set-title $*
    /usr/bin/ssh -2 $*
    set-title $HOST
}

mkcd () {
    case "$1" in
        */..|*/../) cd -- "$1";;
        /*/../*) (cd "${1%/../*}/.." && mkdir -p "./${1##*/../}") && cd -- "$1";;
        /*) mkdir -p "$1" && cd "$1";;
        */../*) (cd "./${1%/../*}/.." && mkdir -p "./${1##*/../}") && cd "./$1";;
        ../*) (cd .. && mkdir -p "${1#.}") && cd "$1";;
        *) mkdir -p "./$1" && cd "./$1";;
    esac
}

# Yazi helper to cd to Yazi's exit directory.
function y() {
    local tmp="$(mktemp -t "yazi-cwd.XXXXXX")"
    yazi "$@" --cwd-file="$tmp"
    if cwd="$(cat -- "$tmp")" && [ -n "$cwd" ] && [ "$cwd" != "$PWD" ]; then
        builtin cd -- "$cwd"
    fi
    rm -f -- "$tmp"
}

separator() {
    if [[ -z $COLUMNS ]]; then
        COLUMNS=$(tput cols)
    fi
    local lengthOfTitle=$((${#1}+2))
    local numberOfCharacters=$(( ($COLUMNS - $lengthOfTitle)/2 ))
    printf "=%.0s"  $(seq 1 ${numberOfCharacters}); printf " ${1} "; printf "=%.0s"  $(seq 1 ${numberOfCharacters}); printf "\n"
}

# ─── Platform-specific additions ───────────────────────────────────────
# Mac adds Homebrew paths and nrs alias (see zshrc.darwin).
# Linux adds kiro, claude-mem, auto-tmux-launch (see zshrc.linux).
if [[ "$OSTYPE" == darwin* ]] && [ -r "$HOME/dotfiles/configs/zsh/zshrc.darwin" ]; then
    source "$HOME/dotfiles/configs/zsh/zshrc.darwin"
elif [[ "$OSTYPE" == linux* ]] && [ -r "$HOME/dotfiles/configs/zsh/zshrc.linux" ]; then
    source "$HOME/dotfiles/configs/zsh/zshrc.linux"
fi
